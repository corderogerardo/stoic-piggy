{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "RCT_USE_RN_DEP": "1",
        "RCT_USE_PREBUILT_RNCORE": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://stoic-piggy-api.onrender.com/trpc",
        "RCT_USE_RN_DEP": "1",
        "RCT_USE_PREBUILT_RNCORE": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://stoic-piggy-api.onrender.com/trpc",
        "RCT_USE_RN_DEP": "1",
        "RCT_USE_PREBUILT_RNCORE": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6783594748"
      }
    }
  }
}
