# Parents dashboard — environment variables

# Where the NestJS tRPC API is mounted (REST lives at /api, tRPC at /trpc).
NEXT_PUBLIC_API_URL=http://localhost:3001/trpc

# Which seeded parent's children to show in the dashboard demo.
# Matches a parent id from apps/backend/prisma/seed.ts (seed-parent | seed-parent-2 | seed-parent-3).
NEXT_PUBLIC_DEMO_PARENT_ID=seed-parent
