// Stoic Piggy — Prisma schema (PostgreSQL / Supabase)
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Parent {
  id           String   @id @default(cuid())
  email        String   @unique
  // bcrypt hash of the parent's password. Set on register; never returned to clients.
  passwordHash String
  displayName  String
  // Null until the parent confirms ownership of their email via the verification
  // link. We soft-gate: an unverified parent can still use the dashboard.
  emailVerifiedAt DateTime?
  // Parent preferences (shown on the Settings page).
  notifyEnabled       Boolean @default(true)
  weeklyReportEnabled Boolean @default(true)
  // When true, a kid's submitted task is approved + paid out automatically.
  autoApproveTasks    Boolean @default(false)
  // How money is delivered on approval (card | bank | cash). Display-only for now.
  payoutMethod        String  @default("card")
  children     Child[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Single-use email-verification tokens. We store only a SHA-256 hash of the raw
// token (the raw value lives only in the emailed link), so a DB leak can't be
// replayed. `consumedAt` makes a token one-shot; `expiresAt` bounds its lifetime.
model EmailVerificationToken {
  id         String    @id @default(cuid())
  parent     Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId   String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([parentId])
}

// Single-use password-reset tokens. Same hashed, expiring, one-shot design as
// EmailVerificationToken (shorter TTL — a reset link is more sensitive).
model PasswordResetToken {
  id         String    @id @default(cuid())
  parent     Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId   String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([parentId])
}

model Child {
  id          String        @id @default(cuid())
  parent      Parent        @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId    String
  displayName String
  // Globally-unique login handle the kid types in the mobile app. Created by a parent.
  username     String        @unique
  // bcrypt hash of the kid's password (set by the parent on account creation).
  passwordHash String
  avatarUrl   String?
  level          Int           @default(1)
  xp             Int           @default(0)
  age            Int?
  allowanceCents Int           @default(0)
  autopayEnabled Boolean       @default(false)
  // Null = active. Set when a parent deactivates the kid: blocks login + hides the
  // kid from the dashboard, but preserves their history (vs a hard delete).
  deactivatedAt  DateTime?
  piggyBanks  PiggyBank[]
  goals       SavingsGoal[]
  quests      Quest[]
  tasks       Task[]
  resistedImpulses ResistedImpulse[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([parentId])
}

model PiggyBank {
  id           String        @id @default(cuid())
  child        Child         @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId      String
  name         String
  balanceCents Int           @default(0)
  currency     String        @default("USD")
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([childId])
}

enum TransactionType {
  deposit
  withdrawal
  allowance
  reward
  goal_contribution
}

model Transaction {
  id          String          @id @default(cuid())
  piggyBank   PiggyBank       @relation(fields: [piggyBankId], references: [id], onDelete: Cascade)
  piggyBankId String
  type        TransactionType
  amountCents Int
  note        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([piggyBankId])
}

// How soon the kid aims to reach the goal: short ~1mo, medium ~3mo, long ~6mo.
enum GoalTerm {
  short
  medium
  long
}

// What the goal teaches: a thing to save for, an investment, or a skill/education.
enum GoalCategory {
  thing
  invest
  learn
}

model SavingsGoal {
  id          String       @id @default(cuid())
  child       Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId     String
  title       String
  targetCents Int
  savedCents  Int          @default(0)
  term        GoalTerm     @default(short)
  category    GoalCategory @default(thing)
  achievedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([childId])
}

enum QuestStatus {
  available
  in_progress
  completed
  claimed
}

model Quest {
  id          String      @id @default(cuid())
  child       Child       @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId     String
  title       String
  description String
  rewardXp    Int         @default(0)
  rewardCents Int         @default(0)
  status      QuestStatus @default(available)
  // Links a quest to its in-app lesson (cards + quiz). Null = legacy tap-to-claim.
  lessonKey   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([childId])
}

// Logged each time a kid resists an impulse purchase (the Temptation flow). Powers
// the Wins screen's "resisted" count + total saved-from-impulses.
model ResistedImpulse {
  id          String   @id @default(cuid())
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId     String
  amountCents Int      @default(0)
  item        String?
  createdAt   DateTime @default(now())

  @@index([childId])
}

enum TaskCategory {
  chore
  lesson
}

enum TaskPayType {
  money
  xp
  both
}

enum TaskRecurrence {
  once
  daily
  weekly
  monthly
}

enum TaskStatus {
  active
  submitted
  approved
  rejected
}

// A parent-assigned chore/lesson with an approval + pay loop (distinct from Quest,
// which is the kid's self-serve missions). The kid marks it done (submitted), the
// parent approves (credits the kid's piggy bank and/or awards XP) or rejects.
model Task {
  id          String         @id @default(cuid())
  child       Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId     String
  title       String
  category    TaskCategory   @default(chore)
  payType     TaskPayType    @default(money)
  amountCents Int            @default(0)
  rewardXp    Int            @default(0)
  recurrence  TaskRecurrence @default(once)
  status      TaskStatus     @default(active)
  dueAt       DateTime?
  note        String?
  submittedAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([childId])
}
