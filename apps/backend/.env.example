# ---- Runtime ----
PORT=3001
NODE_ENV=development

# ---- Auth ----
# Secret used to sign/verify JWT bearer tokens. REQUIRED in production
# (the app refuses to boot without it). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="dev-secret-change-me"

# ---- Email (Resend) ----
# API key for sending verification + password-reset emails. When UNSET, the
# backend logs the email link to the console instead of sending (dev/test only).
RESEND_API_KEY=""
# Verified sender. Defaults to Resend's onboarding address (only delivers to your
# own Resend account email) — set a verified-domain sender for real delivery.
EMAIL_FROM="Stoic Piggy <onboarding@resend.dev>"
# Public origin of the parents dashboard, used to build links in emails
# (e.g. ${APP_URL}/verify-email?token=… and /reset-password?token=…).
APP_URL="http://localhost:3002"

# ---- Supabase Postgres ----
# Pooled connection (Supavisor / PgBouncer, port 6543) used by the app at runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) used by Prisma Migrate.
DIRECT_URL="postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Supabase project (optional: auth / storage) ----
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
