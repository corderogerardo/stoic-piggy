{
  "name": "@stoicpiggy/schemas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@stoicpiggy/typescript-config": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
