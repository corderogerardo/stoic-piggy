{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "expo": {
      "command": "pnpm",
      "args": [
        "--filter",
        "@stoicpiggy/mobile",
        "exec",
        "expo-mcp",
        "--dev-server-url",
        "http://localhost:8081"
      ]
    }
  }
}
