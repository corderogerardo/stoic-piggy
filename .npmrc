# React Native / Expo + Metro do not understand pnpm's symlinked node_modules,
# so we use a flat (hoisted) layout for the whole workspace.
node-linker=hoisted

# RN/Expo peer graphs are noisy; auto-install peers and don't fail the install.
auto-install-peers=true
strict-peer-dependencies=false
dedupe-peer-dependents=true

# Keep workspace packages linked locally.
link-workspace-packages=true
